# =============================================================================
# .gitignore — Learning Assistant (MCP Servers)
# =============================================================================
# Organized by: IDE → Build → Runtime → OS → Secrets
# Last reviewed: comprehensive audit for best practices
# =============================================================================

# =============================================================================
# IDE — IntelliJ IDEA
# =============================================================================
# Selective .idea/ tracking following JetBrains' official recommendation:
#   https://intellij-support.jetbrains.com/hc/en-us/articles/206544839
#
# Strategy: ignore everything in .idea/, then un-ignore shareable project configs.
# This ensures new plugin/state files are ignored by default (safe baseline),
# while team-relevant settings (code style, inspections, SDK level) are committed.

# --- Ignore all .idea/ contents by default ---
.idea/*

# --- Un-ignore shareable project-level configs ---
# IntelliJ's own .gitignore (ignores workspace.xml, shelf/, etc.)
!.idea/.gitignore
# Code style / formatting settings (project-level)
!.idea/codeStyles/
# Inspection profiles (project-level)
!.idea/inspectionProfiles/
# Project SDK and language level
!.idea/misc.xml
# Module list (which .iml files compose the project)
!.idea/modules.xml
# VCS integration (Git root mappings)
!.idea/vcs.xml
# Shared run/debug configurations (when stored in .idea/)
!.idea/runConfigurations/
# Custom scopes (shareable named file scopes)
!.idea/scopes/
# Compiler settings (annotation processors, bytecode version)
!.idea/compiler.xml
# File encoding settings
!.idea/encodings.xml
# Copyright profile headers
!.idea/copyright/

# --- Remaining user/machine-specific files stay ignored via .idea/* ---
# workspace.xml, shelf/, tasks.xml, usage.statistics.xml, plugin state XMLs,
# dataSources/, httpRequests/, dictionaries/ — all covered by the wildcard.

# Module definition files — contain source roots, dependencies, and output paths.
# Committed because this project uses manual compilation (no Maven/Gradle).
# If a build tool is adopted later, add *.iml back to .gitignore.
# *.iml  ← intentionally tracked (see above)
*.iws
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/
.kotlin

# =============================================================================
# IDE — Eclipse
# =============================================================================
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# =============================================================================
# IDE — NetBeans
# =============================================================================
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# =============================================================================
# IDE — VS Code
# =============================================================================
# Root .vscode is ignored (personal settings) except project-level files below.
.vscode/*
!.vscode/tasks.json
# mcp.json is a project-level MCP server registry (no secrets — uses VS Code inputs for credentials)
!.vscode/mcp.json
# launch.json contains debug/run configurations for MCP servers — project-level, portable
!.vscode/launch.json
# But mcp-servers/.vscode IS committed (portable config for copying to other projects)
!mcp-servers/.vscode/

# .code-workspace files — ignored because this is a single-root project.
# Opening the folder directly gives the identical experience.
# If the project becomes multi-root or gains shared workspace settings, un-ignore this.
*.code-workspace

# =============================================================================
# Java Build Artifacts
# =============================================================================
*.class
*.jar
*.war
*.ear
target/
build/
.gradle/

# =============================================================================
# Dependency & Runtime Artifacts (global)
# =============================================================================
node_modules/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# =============================================================================
# MCP Server Build/Runtime Artifacts
# =============================================================================
mcp-servers/out/

# =============================================================================
# Script Runtime Artifacts
# =============================================================================
# PID files generated by browser launch/close scripts
scripts/.browser-pid
mcp-servers/scripts/.browser-pid

# =============================================================================
# MCP Config — Layered configuration strategy
# =============================================================================
# mcp-config.properties              ← COMMITTED (safe defaults, no secrets)
# mcp-config.local.properties        ← GITIGNORED (developer's secrets/overrides)
# mcp-config.local.example.properties ← COMMITTED (template for the local file)
#
# This follows the industry-standard pattern:
#   Spring Boot:  application.properties (committed) + application-local.properties (ignored)
#   .env pattern: .env (ignored) + .env.example (committed)
#   12-Factor App: config from environment, not committed files
#
mcp-servers/user-config/mcp-config.local.properties
# Server-specific local config files (credentials, instance URLs)
# Pattern covers all servers under user-config/servers/**/
mcp-servers/user-config/servers/**/*.local.properties
# OAuth credential stores (tokens, refresh tokens — sensitive)
mcp-servers/user-config/servers/**/credentials/*.properties

# Local build environment file (machine-specific JDK path, never commit)
mcp-servers/build.env.local

# =============================================================================
# Brain workspace (brain/ directory) -- personal knowledge management
# =============================================================================
# brain/inbox/   -- session-scoped throwaway (never committed)
# brain/notes/   -- curated session notes, committed to the repo (tracked git)
# brain/library/ -- permanent reference library, committed to the repo (tracked git)
#
# Tier tracking:
#   inbox/   → GITIGNORED  (raw captures, cleared per session)
#   notes/   → TRACKED     (reviewed, permanent developer knowledge)
#   library/ → TRACKED     (formally published with tags + git commit)

brain/ai-brain/inbox/

# =============================================================================
# OS Generated Files
# =============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
$RECYCLE.BIN/

# =============================================================================
# Logs & Temp Files
# =============================================================================
*.log
*.tmp
*.bak
*.swp
*.swo
*~

# =============================================================================
# Environment & Secrets — NEVER commit credentials
# =============================================================================
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
*.jks
*.keystore