# =============================================================================
# Atlassian Tools Skill — PAT Token Configuration (Single Account)
# =============================================================================
#
# Copy this file to `.env` in the SAME directory (or workspace root) and fill
# in your Personal Access Tokens and base URLs.
#
#   cp .env.example .env
#
# Rules:
#   - No quotes around values — store raw token strings
#   - PATs often contain +, /, = characters (Base64) — this is normal
#   - Lines starting with # are comments
#   - One KEY=VALUE per line, no spaces around the =
#   - This file (.env) is gitignored — never committed
#   - You only need tokens for services you actually use
#
# Token generation:
#   Jira:       Profile → Personal Access Tokens → Create
#   Confluence: Profile → Settings → Personal Access Tokens → Create
#   Bitbucket:  Profile → Manage Account → HTTP Access Tokens → Create
#
# CLI load order (later overrides earlier):
#   1. <workspace>/.env           ← workspace root (primary)
#   2. <skill>/.env               ← .github/skills/atlassian-tools/.env (override)
#   3. $env:ENV_FILE              ← explicit path (highest priority)
#
# =============================================================================

# --- Jira ---
JIRA_PAT_TOKEN=your-jira-pat-token-here
JIRA_BASE_URL=https://your-jira-instance.example.com

# --- Confluence ---
CONFLUENCE_PAT_TOKEN=your-confluence-pat-token-here
CONFLUENCE_BASE_URL=https://your-confluence-instance.example.com

# --- Bitbucket ---
BITBUCKET_PAT_TOKEN=your-bitbucket-pat-token-here
BITBUCKET_BASE_URL=https://your-bitbucket-instance.example.com

# --- TLS (optional) ---
# Corporate environments with internal CAs: set the CA bundle path.
# If not set, the CLI defaults to NODE_TLS_REJECT_UNAUTHORIZED=0.
# NODE_EXTRA_CA_CERTS=/path/to/corporate-ca-bundle.pem
