# =============================================================================
# Atlassian Tools Skill — Multi-Account Configuration Template
# =============================================================================
#
# Use this template for ADDITIONAL Atlassian instances beyond your default .env.
# Copy and rename for each account you need:
#
#   cp .env.accounts.example .env.work-jira        ← your work Jira instance
#   cp .env.accounts.example .env.personal-conf     ← your personal Confluence
#   cp .env.accounts.example .env.client-bb         ← a client's Bitbucket
#
# Naming conventions:
#   .env.<purpose>-<service>    e.g., .env.work-jira, .env.client-confluence
#   .env.<instance-name>        e.g., .env.acme-corp, .env.siemens-eda
#   .env.account-b              e.g., generic second account
#
# All .env.* files are gitignored (except .env.example and .env.template).
#
# You only need to include variables that DIFFER from your default .env.
# Unset variables fall back to whatever is already in the environment.
#
# =============================================================================
#
# USAGE — 3 strategies for switching accounts:
#
# Strategy 1: Environment variable swap (recommended for one-off operations)
#   $saved = $env:CONFLUENCE_PAT_TOKEN
#   $env:CONFLUENCE_PAT_TOKEN = "other-token"
#   # ... do work ...
#   $env:CONFLUENCE_PAT_TOKEN = $saved
#
# Strategy 2: Load-EnvFile helper (recommended for multi-step workflows)
#   function Load-EnvFile($path) {
#       Get-Content $path | ForEach-Object {
#           if ($_ -match '^\s*([^#][^=]+)=(.*)$') {
#               [System.Environment]::SetEnvironmentVariable(
#                   $Matches[1].Trim(), $Matches[2].Trim(), "Process")
#           }
#       }
#   }
#   Load-EnvFile ".github/skills/atlassian-tools/.env.work-jira"
#   # ... do work ...
#   Load-EnvFile ".github/skills/atlassian-tools/.env"   # restore default
#
# Strategy 3: ENV_FILE override (recommended for single CLI calls)
#   $env:ENV_FILE = "$PWD/.github/skills/atlassian-tools/.env.work-jira"
#   # ... one CLI call ...
#   Remove-Item Env:\ENV_FILE
#
# VALIDATION — always verify you are targeting the correct instance:
#   $env:CLI_JSON_ARGS = '{}'; node ".github/skills/atlassian-tools/scripts/atlassian_cli.js" get_current_jira_user
#   $env:CLI_JSON_ARGS = '{}'; node ".github/skills/atlassian-tools/scripts/atlassian_cli.js" get_current_confluence_user
#
# =============================================================================

# --- Jira (include only if this account has a different Jira instance) ---
# JIRA_PAT_TOKEN=your-other-jira-pat-token
# JIRA_BASE_URL=https://other-jira.example.com

# --- Confluence (include only if this account has a different Confluence) ---
# CONFLUENCE_PAT_TOKEN=your-other-confluence-pat-token
# CONFLUENCE_BASE_URL=https://other-confluence.example.com

# --- Bitbucket (include only if this account has a different Bitbucket) ---
# BITBUCKET_PAT_TOKEN=your-other-bitbucket-pat-token
# BITBUCKET_BASE_URL=https://other-bitbucket.example.com

# --- TLS (optional — usually only needed for instances with different CAs) ---
# NODE_EXTRA_CA_CERTS=/path/to/other-ca-bundle.pem
