# =============================================================================
# .env.example — Learning Assistant environment template
#
# USAGE:
#   Copy this file to .env and fill in the values for your machine.
#   The .env file is gitignored — never commit it.
#
#   Windows:  copy .env.example .env   (then edit .env)
#   Mac/Linux: cp .env.example .env    (then edit .env)
#
# LOADING the environment:
#   Windows PowerShell:  . .\setup.ps1
#   Mac / Linux bash:    source ./setup.sh
# =============================================================================

# --- Required ---

# Full path to a JDK 21+ installation (must be a JDK, not a JRE).
# This is used by Gradle toolchain resolution and the Gradle daemon itself.
#
# Windows example:  JAVA_HOME=E:/mgcnoscan/JDKs/jdk-21.0.10
# Mac example:      JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-21.jdk/Contents/Home
JAVA_HOME=

# Root of this repository on your machine.
# Used by scripts to locate config, modules, and build artefacts.
#
# Windows example:  PROJ_HOME=E:/mgcnoscan/learning/learning-assistant
# Mac example:      PROJ_HOME=/Users/yourname/dev/learning-assistant
PROJ_HOME=

# --- Optional ---

# Temporary scratch directory for build artefacts that should not live in build/.
# Defaults to $PROJ_HOME/temp if not set.
#
# Windows example:  PROJ_TEMP=E:/mgcnoscan/learning/learning-assistant/temp
# Mac example:      PROJ_TEMP=/Users/yourname/dev/learning-assistant/temp
PROJ_TEMP=

# Override the Gradle user home (where Gradle caches and daemons live).
# Useful on machines with limited space on the default drive.
# Defaults to ~/.gradle if not set.
#
# Windows example:  GRADLE_USER_HOME=E:/gradle-cache
# Mac example:      GRADLE_USER_HOME=/Users/yourname/.gradle-cache
GRADLE_USER_HOME=
